{
  "name": "@r2d2bzh/moleculer-test-utils",
  "version": "1.2.1",
  "description": "Some useful functions for moleculer unit testing",
  "main": "lib/index.js",
  "type": "module",
  "scripts": {
    "pretest": "npm install",
    "lint": "eslint .",
    "test": "docker compose run test",
    "posttest": "npm run build:types",
    "test:docker": "c8 ava",
    "build:types": "tsc --declaration --allowJs --emitDeclarationOnly lib/index.js",
    "release": "release-it"
  },
  "author": "r2d2bzh",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "moleculer": "^0.14.35",
    "mongodb": "^7.1.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "@r2d2bzh/eslint-config": "^2.0.1",
    "ava": "^6.4.1",
    "c8": "^10.1.3",
    "typescript": "^5.9.3",
    "release-it": "^19.2.4",
    "@release-it/conventional-changelog": "^10.0.1"
  },
  "c8": {
    "check-coverage": true,
    "statements": 100,
    "branches": 100,
    "functions": 100,
    "lines": 100,
    "all": true,
    "allowExternal": true,
    "src": [
      "./lib"
    ],
    "reporter": [
      "lcov",
      "text"
    ]
  }
}
