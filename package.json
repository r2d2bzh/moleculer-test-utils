{
  "name": "@r2d2bzh/moleculer-test-utils",
  "version": "1.3.0",
  "description": "Some useful functions for moleculer unit testing",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "type": "module",
  "scripts": {
    "pretest": "npm install",
    "lint": "eslint .",
    "test": "docker compose run --rm test",
    "posttest": "npm run build:types",
    "test:docker": "c8 ava",
    "prebuild:types": "node -e \"const fs=require('fs');fs.readdirSync('lib').filter(f=>f.endsWith('.d.ts')).forEach(f=>fs.unlinkSync('lib/'+f))\"",
    "build:types": "tsc && eslint --fix lib/*.d.ts",
    "release": "release-it"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r2d2bzh/moleculer-test-utils.git"
  },
  "bugs": {
    "url": "https://github.com/r2d2bzh/moleculer-test-utils/issues"
  },
  "homepage": "https://github.com/r2d2bzh/moleculer-test-utils#readme",
  "author": "r2d2bzh",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "moleculer": "^0.14.35",
    "mongodb": "^7.4.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@r2d2bzh/eslint-config": "^3.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^24.1.0",
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "release-it": "^20.2.0",
    "typescript": "^6.0.3"
  },
  "c8": {
    "check-coverage": true,
    "statements": 100,
    "branches": 100,
    "functions": 100,
    "lines": 100,
    "all": true,
    "allowExternal": true,
    "src": [
      "./lib"
    ],
    "reporter": [
      "lcov",
      "text"
    ]
  }
}
